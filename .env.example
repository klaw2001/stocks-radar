# Results Radar v2 — Environment Variables
# Copy this file to .env and fill in your values

# ─── Viewer Auth ───────────────────────────────────────────────────────────────
# Comma-separated list of username:password pairs.
# Leave blank to run without any login gate (publicly accessible).
USERS=alice:password1,bob:password2

# Random secret used to sign session cookies — change this to something long!
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Anyone with this key can toggle read/unread on results.
ADMIN_KEY=your-secret-admin-key

# ─── Twitter / X API ───────────────────────────────────────────────────────────
# Requires X API Basic tier ($100/month) for tweets/search/recent access.
# Leave blank to run in mock mode (random sentiment, no errors).
X_BEARER_TOKEN=

# ─── Tijori Finance ────────────────────────────────────────────────────────────
# API key for concall transcript and AI summary polling.
# Leave blank to run in mock mode (transcripts randomly promoted to available).
TIJORI_CONCALL_MONITOR_API_KEY=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
